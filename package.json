{
  "name": "minerva",
  "version": "0.1.0",
  "description": "Objective-driven optimization agent — you bring the goal, Minerva finds the wisest move, proven by your Dynatrace data",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:live": "MINERVA_LIVE=1 tsx watch src/index.ts",
    "agent:smoke": "tsx src/agent/smoke.ts",
    "web": "python3 -m http.server 8080 --directory web",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "dynatrace",
    "optimization",
    "decision-intelligence",
    "gemini",
    "google-cloud",
    "agent",
    "mcp"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@google-cloud/vertexai": "1.9.2",
    "@google/adk": "1.2.0",
    "@google/adk-devtools": "1.2.0",
    "@hono/node-server": "1.19.14",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "hono": "4.12.23"
  },
  "devDependencies": {
    "@eslint/js": "9.27.0",
    "@types/node": "22.15.17",
    "eslint": "9.27.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "typescript-eslint": "8.32.1",
    "vitest": "3.1.3"
  }
}
