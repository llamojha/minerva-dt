{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "web",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "fixtures/**"
    }
  },
  "rewrites": [{ "source": "/api/(.*)", "destination": "/api/index" }]
}
