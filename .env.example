# Dynatrace
DT_ENVIRONMENT=https://your-env.apps.dynatrace.com
DT_PLATFORM_TOKEN=your-platform-token
DT_GRAIL_QUERY_BUDGET_GB=10

# Token for the telemetry generator (gen/telemetry.mjs). OTLP trace ingest needs the
# `openpipeline:traces:ingest` scope. Add it to DT_PLATFORM_TOKEN, or set a separate token here.
DT_INGEST_TOKEN=your-ingest-scoped-token

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-project-id
GEMINI_API_KEY=your-gemini-key

# Optional
NODE_ENV=development
